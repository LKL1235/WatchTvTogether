{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "api": {
      "entrypoint": ".",
      "routePrefix": "/api",
      "framework": "go"
    },
    "ws": {
      "entrypoint": ".",
      "routePrefix": "/ws",
      "framework": "go"
    },
    "static": {
      "entrypoint": ".",
      "routePrefix": "/static",
      "framework": "go"
    },
    "healthz": {
      "entrypoint": ".",
      "routePrefix": "/healthz",
      "framework": "go"
    }
  },
  "build": {
    "env": {
      "STORAGE_BACKEND": "postgres",
      "CACHE_BACKEND": "redis"
    }
  }
}
