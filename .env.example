# ─── WatchTogether 生产环境配置示例 ──────────────────────────────────────────
# 复制为 .env 并填写实际值后，运行 docker compose up -d

# PostgreSQL
POSTGRES_USER=watchtogether
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=watchtogether

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT
JWT_SECRET=change_me_jwt_secret_at_least_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# OAuth（不需要的 Provider 留空即可）
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# Docker 镜像
GITHUB_REPOSITORY=owner/watchtogether
IMAGE_TAG=latest

# 应用对外端口（默认 8080）
APP_PORT=8080
