ADDR=:8080
# Optional: path to Vite build output when Go serves the SPA (e.g. FRONTEND_DIST=frontend/dist on Vercel).
# STATIC_ROOT=frontend/dist
#
# Local Docker / self-hosted (example):
STORAGE_BACKEND=postgres
SQLITE_PATH=/data/watchtogether.db
POSTGRES_DSN=postgres://watchtogether:watchtogether@postgres:5432/watchtogether?sslmode=disable
# Vercel Postgres usually provides DATABASE_URL instead of POSTGRES_DSN.
# DATABASE_URL=
CACHE_BACKEND=redis
REDIS_ADDR=redis:6379
# Vercel / Upstash often provide REDIS_URL (rediss://...); when set it overrides REDIS_ADDR.
# REDIS_URL=
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
STORAGE_DIR=/data/videos
POSTER_DIR=/data/posters
DOWNLOAD_WORKERS=2
ARIA2_RPC_URL=http://aria2:6800/jsonrpc
ARIA2_SECRET=
