ADDR=:8080
# Local Docker / self-hosted (example):
STORAGE_BACKEND=postgres
SQLITE_PATH=/data/watchtogether.db
POSTGRES_DSN=postgres://watchtogether:watchtogether@postgres:5432/watchtogether?sslmode=disable
# Some platforms provide DATABASE_URL instead of POSTGRES_DSN.
# DATABASE_URL=
CACHE_BACKEND=redis
REDIS_ADDR=redis:6379
# REDIS_URL (rediss://...) overrides REDIS_ADDR when set.
# REDIS_URL=
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
STORAGE_DIR=/data/videos
POSTER_DIR=/data/posters
DOWNLOAD_WORKERS=2
ARIA2_RPC_URL=http://aria2:6800/jsonrpc
ARIA2_SECRET=
