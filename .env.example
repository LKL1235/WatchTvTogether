ADDR=:8080
STORAGE_BACKEND=postgres
POSTGRES_DSN=postgres://watchtogether:watchtogether@postgres:5432/watchtogether?sslmode=disable
# Some platforms provide DATABASE_URL instead of POSTGRES_DSN.
# DATABASE_URL=
CACHE_BACKEND=redis
REDIS_ADDR=redis:6379
# REDIS_URL (rediss://...) overrides REDIS_ADDR when set.
# REDIS_URL=
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Server-side only. Configure in backend/Vercel environment variables; never expose
# this value to frontend build variables.
ABLY_ROOT_KEY=appId.keyId:keySecret
ABLY_TOKEN_TTL=30m
ABLY_CHANNEL_PREFIX=watchtogether
STORAGE_DIR=/data/videos
POSTER_DIR=/data/posters
DOWNLOAD_WORKERS=2
ARIA2_RPC_URL=http://aria2:6800/jsonrpc
ARIA2_SECRET=
